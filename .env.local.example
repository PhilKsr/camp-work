# MapTiler API Key
# Get your free API key from https://maptiler.com
NEXT_PUBLIC_MAPTILER_KEY=your_key_here

# Optional: Database URL for storing user data
# DATABASE_URL=postgres://username:password@localhost:5432/campwork

# Optional: Auth providers (if implementing authentication)
# NEXTAUTH_SECRET=your_secret_here
# NEXTAUTH_URL=http://localhost:3000

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Sentry (error reporting)
# NEXT_PUBLIC_SENTRY_DSN=https://your_dsn@sentry.io/project_id